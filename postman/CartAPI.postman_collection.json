{
  "info": {
    "name": "CartAPI",
    "description": "Manual + Newman-runnable Postman collection for the CartAPI service. Use the CartAPI - Local environment to set baseUrl and chain IDs between requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "userId", "value": ""},
    {"key": "productId", "value": ""},
    {"key": "variantId", "value": ""},
    {"key": "cartId", "value": ""},
    {"key": "itemId", "value": ""}
  ],
  "item": [
    {
      "name": "00 - Setup",
      "item": [
        {
          "name": "Create user (saves userId)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", ""]},
            "body": {"mode": "raw", "raw": "{\"email\": \"postman-{{$timestamp}}@example.com\", \"password\": \"secret123\", \"name\": \"Postman User\"}"}
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Has id', () => pm.expect(pm.response.json().id).to.be.a('number'));",
                "pm.collectionVariables.set('userId', pm.response.json().id);",
                "console.log('Saved userId =', pm.response.json().id);"
              ]
            }
          }]
        },
        {
          "name": "Create product (saves productId)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", ""]},
            "body": {"mode": "raw", "raw": "{\"name\": \"Postman Product\", \"description\": \"Created by Postman\", \"brand\": \"Postman\"}"}
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.collectionVariables.set('productId', pm.response.json().id);",
                "console.log('Saved productId =', pm.response.json().id);"
              ]
            }
          }]
        },
        {
          "name": "Create variant (saves variantId)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/{{productId}}/variants", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}", "variants"]},
            "body": {"mode": "raw", "raw": "{\"sku\": \"POSTMAN-{{$timestamp}}\", \"price\": 29.99, \"currency\": \"USD\", \"inventory_qty\": 50}"}
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.collectionVariables.set('variantId', pm.response.json().id);"
              ]
            }
          }]
        },
        {
          "name": "Create cart (saves cartId)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", ""]},
            "body": {"mode": "raw", "raw": "{\"user_id\": {{userId}}, \"discount\": 0}"}
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Status is ACTIVE', () => pm.expect(pm.response.json().status).to.eql('ACTIVE'));",
                "pm.collectionVariables.set('cartId', pm.response.json().id);"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "01 - Users",
      "item": [
        {
          "name": "Get user by id",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Get user - not found (expect 404)",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/users/99999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "99999"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]}}]
        },
        {
          "name": "Update user (change name)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}"]},
            "body": {"mode": "raw", "raw": "{\"name\": \"Postman User Updated\"}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Get user cart (active cart exists)",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/users/{{userId}}/cart", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}", "cart"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        }
      ]
    },
    {
      "name": "02 - Products",
      "item": [
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", ""]},
            "body": {"mode": "raw", "raw": "{\"name\": \"PM Product 2\", \"description\": \"Second\", \"brand\": \"PM\"}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"]}}]
        },
        {
          "name": "List products",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/products/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", ""]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"]}}]
        },
        {
          "name": "Get product by id",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has variants array', () => pm.expect(pm.response.json().variants).to.be.an('array'));"]}}]
        },
        {
          "name": "Get product - not found (expect 404)",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/products/99999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "99999"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]}}]
        },
        {
          "name": "Update product",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}"]},
            "body": {"mode": "raw", "raw": "{\"name\": \"PM Product Renamed\"}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        }
      ]
    },
    {
      "name": "03 - Variants",
      "item": [
        {
          "name": "Create variant",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/{{productId}}/variants", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}", "variants"]},
            "body": {"mode": "raw", "raw": "{\"sku\": \"PM-VAR-{{$timestamp}}\", \"price\": 15.0, \"currency\": \"USD\", \"inventory_qty\": 20}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"]}}]
        },
        {
          "name": "Get variant by id",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/products/variants/{{variantId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "variants", "{{variantId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Update variant (change price)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/variants/{{variantId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "variants", "{{variantId}}"]},
            "body": {"mode": "raw", "raw": "{\"price\": 35.0}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Get variant - not found (expect 404)",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/products/variants/99999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "variants", "99999"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]}}]
        }
      ]
    },
    {
      "name": "04 - Carts",
      "item": [
        {
          "name": "Create cart",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", ""]},
            "body": {"mode": "raw", "raw": "{\"user_id\": {{userId}}}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.collectionVariables.set('cartId2', pm.response.json().id);"]}}]
        },
        {
          "name": "Get cart by id",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Get cart - not found (expect 404)",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/carts/99999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "99999"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]}}]
        },
        {
          "name": "Create cart with negative discount (expect 422)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", ""]},
            "body": {"mode": "raw", "raw": "{\"user_id\": {{userId}}, \"discount\": -5}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"]}}]
        }
      ]
    },
    {
      "name": "05 - Cart Items",
      "item": [
        {
          "name": "Add item to cart (saves itemId)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/items", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "items"]},
            "body": {"mode": "raw", "raw": "{\"product_variant_id\": {{variantId}}, \"quantity\": 1}"}
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Subtotal > 0', () => pm.expect(pm.response.json().subtotal).to.be.greaterThan(0));",
                "pm.collectionVariables.set('itemId', pm.response.json().items[0].id);"
              ]
            }
          }]
        },
        {
          "name": "Add same item again (expect 409)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/items", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "items"]},
            "body": {"mode": "raw", "raw": "{\"product_variant_id\": {{variantId}}, \"quantity\": 1}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 409', () => pm.response.to.have.status(409));"]}}]
        },
        {
          "name": "Update item quantity",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "items", "{{itemId}}"]},
            "body": {"mode": "raw", "raw": "{\"quantity\": 3}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Quantity is 3', () => pm.expect(pm.response.json().items[0].quantity).to.eql(3));"]}}]
        },
        {
          "name": "Update item with negative quantity (expect 422)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "items", "{{itemId}}"]},
            "body": {"mode": "raw", "raw": "{\"quantity\": -1}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"]}}]
        }
      ]
    },
    {
      "name": "06 - Checkout",
      "item": [
        {
          "name": "Checkout cart (success)",
          "request": {"method": "POST", "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/checkout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "checkout"]}},
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Status is CHECKED_OUT', () => pm.expect(pm.response.json().status).to.eql('CHECKED_OUT'));"
              ]
            }
          }]
        },
        {
          "name": "Add item to checked-out cart (expect 400)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/items", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "items"]},
            "body": {"mode": "raw", "raw": "{\"product_variant_id\": {{variantId}}, \"quantity\": 1}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"]}}]
        },
        {
          "name": "Checkout already-checked-out cart (expect 400)",
          "request": {"method": "POST", "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/checkout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "checkout"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"]}}]
        },
        {
          "name": "Checkout nonexistent cart (expect 404)",
          "request": {"method": "POST", "url": {"raw": "{{baseUrl}}/api/v1/carts/99999/checkout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "99999", "checkout"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]}}]
        }
      ]
    },
    {
      "name": "07 - Error cases",
      "item": [
        {
          "name": "Create user with short password (expect 422)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", ""]},
            "body": {"mode": "raw", "raw": "{\"email\": \"short@example.com\", \"password\": \"abc\", \"name\": \"Short\"}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"]}}]
        },
        {
          "name": "Create user with missing field (expect 422)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", ""]},
            "body": {"mode": "raw", "raw": "{\"email\": \"nofields@example.com\"}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"]}}]
        },
        {
          "name": "Create variant with negative price (expect 422)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/{{productId}}/variants", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}", "variants"]},
            "body": {"mode": "raw", "raw": "{\"sku\": \"NEG-PRICE\", \"price\": -1.0, \"inventory_qty\": 1}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"]}}]
        },
        {
          "name": "Get deleted user (expect 404 after delete)",
          "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/users/99999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "99999"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]}}]
        },
        {
          "name": "Create cart with user_id=0 (expect 422)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/carts/", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", ""]},
            "body": {"mode": "raw", "raw": "{\"user_id\": 0}"}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"]}}]
        }
      ]
    },
    {
      "name": "08 - Cleanup",
      "item": [
        {
          "name": "Delete item from cart",
          "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}", "items", "{{itemId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Delete cart",
          "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/api/v1/carts/{{cartId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "{{cartId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Delete variant",
          "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/api/v1/products/variants/{{variantId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "variants", "{{variantId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Delete product",
          "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Delete user",
          "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/api/v1/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}"]}},
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        }
      ]
    }
  ]
}
