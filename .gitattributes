# Force LF line endings for files that must stay LF in the working tree.
# On Windows with core.autocrlf=true, Git converts LF→CRLF on checkout,
# which breaks shell scripts and config files inside Linux Docker containers.

* text=auto eol=lf

*.sh     text eol=lf
Dockerfile text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.ini    text eol=lf
*.cfg    text eol=lf
*.conf   text eol=lf
*.toml   text eol=lf
*.env.*  text eol=lf
.gitignore text eol=lf
