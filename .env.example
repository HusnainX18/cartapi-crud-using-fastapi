# ---------------------------------------------------------------- #
# CartAPI — example environment configuration
# Copy this file to `.env` and fill in real values.
# Never commit your real .env file.
# ---------------------------------------------------------------- #

# Database connection string (MySQL)
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DB_NAME
# 
# For Local MySQL:
# DATABASE_URL=mysql+pymysql://root:changeme@localhost:3306/shopping_cart_db
# 
# For AWS RDS MySQL:
# DATABASE_URL=mysql+pymysql://db_username:db_password@rds-instance-endpoint.c123456789.us-east-1.rds.amazonaws.com:3306/shopping_cart_db
DATABASE_URL=mysql+pymysql://root:changeme@localhost:3306/shopping_cart_db

# Application metadata
APP_NAME=CartAPI
APP_VERSION=1.0.0

# Set to True only for local development (enables SQL echo, verbose errors)
DEBUG=False

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# When True, logs are also written to logs/app.log.
# In containers / production, leave False so stdout is shipped to CloudWatch.
LOG_TO_FILE=True
